import { analysisAgentService } from '../../services/agent.analysis.service.js'
import { analysisStateService } from '../../services/model.analysisState.service.js'
import { composerService } from '../../services/model.composer.service.js'
import { logger } from '../../services/logger.service.js'

const LOG = '[orchestrator:service]'

export const orchestratorService = {
    getOrchestration,
}

async function getOrchestration({ statePackage, agentMessages, userPrompt }) {
    try {
        const resolvedPrompt = userPrompt ?? statePackage?.user_prompt ?? ''

        const agentOutput = await analysisAgentService.analyze({ messages: agentMessages })

        const analysisState = await analysisStateService.updateAfterAgent({
            statePackage,
            agentOutput,
            userPrompt: resolvedPrompt,
        })

        const reply = await composerService.composeResponse(agentOutput)
        return { reply, analysisState }
    } catch (err) {
        console.log(LOG, 'error', err)
        logger.error('Failed to run orchestration', err)
        throw err
    }
}


