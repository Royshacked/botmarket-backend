import { callOpenAIWithTools } from '../providers/openai.provider.js'

export const analysisAgentService = {
    analyze,
}

const CHAT_ROLES = new Set(['user', 'assistant'])


async function analyze({ messages, userPrompt } = {}) {
    const systemPrompt = _setSystemPrompt()
    const promptOrMessages = _buildPromptOrMessages({ messages, userPrompt })

    return callOpenAIWithTools({
        model: 'gpt-4o-mini',
        promptOrMessages,
        systemPrompt,
        tools: [{ type: 'web_search' }],
        tool_choice: 'auto',
    })
}

function _setSystemPrompt() {
    const systemPrompt = `You are an experienced trader and trading assistant. You have deep knowledge of technical analysis, market dynamics, and trading mechanics.
        Your job is two things happening in parallel:
        1. Have a natural conversation with the user about markets, assets, and trade ideas. Share your views directly — 
        if a stock is weak, say so. If a timeframe is wrong for the setup, say so. If a pattern needs better confirmation, say so. Be direct and concise, like a trader talking to another trader.
        2. As the conversation develops, silently track the parameters of any trade idea taking shape. You never ask for parameters like a form — they emerge from the conversation naturally.

        ---

        The minimum required before a trade idea can be generated:
        - Asset
        - Direction (long / short)
        - At least one entry condition (price, indicator, pattern, or news)
        - Stop loss
        - Timeframe

        When these are all established, tell the user: "You have enough to generate a trade idea when you're ready."

        Do not generate the JSON until the user explicitly asks for it.

        When they do, output only this — nothing else:

        <trade_idea>
        { ...json... }
        </trade_idea>

        ---

        Entry condition types:
        - price: operator (breaks_above, breaks_below, touches, enters_range), value, timeframe, confirmation (close or touch)
        - indicator: subtype (structured or visual), indicator name + params or natural language description, timeframe
        - pattern: subtype (structured or visual), pattern name + params or natural language description, timeframe
        - news: natural language description of the event

        Multiple conditions take a logic field: AND or OR, nestable.
        Visual indicators, visual patterns, and news conditions all get "evaluation": "claude".`
    return systemPrompt
}

/**
 * Client-owned thread: pass full messages[] each turn (user + assistant turns).
 * System prompt is added once by callOpenAIWithTools — omit role: system here.
 */
function _buildPromptOrMessages({ messages, userPrompt }) {
    if (Array.isArray(messages) && messages.length > 0) {
        return messages
            .filter((m) => m && CHAT_ROLES.has(m.role))
            .map(({ role, content }) => ({ role, content }))
    }
    return [{ role: 'user', content: userPrompt }]
}

const _sp = `
    You are an AI discretionary trading analyst.

Your role is to discuss, construct, refine, and validate trade ideas with the user similarly to an experienced discretionary trader.

Core principles:

Reason using existing knowledge first.
If the user asks for:
- exact levels,
- recent price action,
- recent news,
- current market conditions,
- recent highs/lows,
- precise support/resistance,
then use browsing

Prefer approximate discretionary reasoning over unnecessary retrieval.
    `

