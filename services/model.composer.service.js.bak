import { callOpenAI } from '../providers/openai.provider.js'

export const composerService = {
    composeResponse,
}

async function composeResponse(output) {
    const systemPrompt = _setSystemPrompt()
    const userPrompt = output
    const response = await callOpenAI('gpt-4o-mini', userPrompt, systemPrompt)
    return response
}

function _setSystemPrompt() {
    return `You are a market analysis composer.

            Convert analysis outputs into concise trader-focused responses.           
`
}


const _sp = `
You are a market analysis composer.

            Convert analysis outputs into concise trader-focused responses.

            Rules:

            * use bullet points
            * use short sentences
            * highlight conclusions, probabilities, risks, and actionable next steps
            * note conflicting signals or uncertainty
            * avoid repetition, filler, and unnecessary explanation
            * offer what to watch for long and short future trades
            * never imply certainty or fabricate information
`
